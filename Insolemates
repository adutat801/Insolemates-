// MARK: - Forgot Password
struct ForgotPasswordView: View {
    @State private var email: String = ""
    @State private var statusMessage: String?
    @State private var isSending = false

    var body: some View {
        Form {
            Section(header: Text("Reset password")) {
                TextField("Email address", text: $email)
                    .keyboardType(.emailAddress)
                    .textInputAutocapitalization(.never)
                    .autocorrectionDisabled()
            }

            Section {
                Button { sendReset() } label: {
                    HStack {
                        Spacer()
                        if isSending { ProgressView() } else { Text("Send reset email") }
                        Spacer()
                    }
                }
                .disabled(isSending || email.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty)
            }

            if let statusMessage {
                Section {
                    Text(statusMessage)
                        .font(.footnote)
                        .foregroundStyle(.secondary)
                }
            }
        }
        .navigationTitle("Forgot Password")
    }

    private func sendReset() {
        let cleanEmail = email.trimmingCharacters(in: .whitespacesAndNewlines)
        guard !cleanEmail.isEmpty else { return }

        isSending = true
        statusMessage = nil

        Auth.auth().sendPasswordReset(withEmail: cleanEmail) { error in
            isSending = false
            if let error = error {
                statusMessage = "Could not send reset email: \(error.localizedDescription)"
            } else {
                statusMessage = "If an account exists for \(cleanEmail), you’ll receive an email with reset instructions."
            }
        }
    }
}

// MARK: - Authentification View
struct AuthView: View {
    enum Mode { case signIn, signUp }

    let initialSignupRole: Role

    @Environment(\.dismiss) private var dismiss
    @State private var mode: Mode = .signIn

    @State private var email: String = ""
    @State private var password: String = ""
    @State private var signupRole: Role = .caregiver

    @State private var isWorking: Bool = false
    @State private var showError: Bool = false
    @State private var errorMessage: String = "Something went wrong."

    private let auth = AuthService()

    init(initialSignupRole: Role) {
        self.initialSignupRole = initialSignupRole
        _signupRole = State(initialValue: initialSignupRole)
        _mode = State(initialValue: .signIn)
    }

    var body: some View {
        Form {
            Section {
                Picker("Mode", selection: $mode) {
                    Text("Sign In").tag(Mode.signIn)
                    Text("Create Account").tag(Mode.signUp)
                }
                .pickerStyle(.segmented)
            }

            Section(header: Text(mode == .signIn ? "Sign in" : "Create account")) {
                TextField("Email", text: $email)
                    .textContentType(.username)
                    .keyboardType(.emailAddress)
                    .textInputAutocapitalization(.never)
                    .autocorrectionDisabled()

                SecureField("Password", text: $password)
                    .textContentType(.password)

                if mode == .signUp {
                    Picker("Role", selection: $signupRole) {
                        Text("Caregiver").tag(Role.caregiver)
                        Text("Physician").tag(Role.physician)
                    }
                }

                NavigationLink("Forgot password?", destination: ForgotPasswordView())
                    .font(.footnote)
            }

            Section {
                Button { submit() } label: {
                    HStack {
                        Spacer()
                        if isWorking { ProgressView() }
                        else { Text(mode == .signIn ? "Sign In" : "Create Account") }
                        Spacer()
                    }
                }
                .disabled(isWorking)
            }
        }
        .navigationTitle("Account")
        .toolbar {
            ToolbarItem(placement: .topBarTrailing) {
                Button("Done") { dismiss() }
            }
        }
        .alert("Error", isPresented: $showError) {
            Button("OK", role: .cancel) { }
        } message: {
            Text(errorMessage)
        }
    }

    private func submit() {
        let cleanEmail = email.trimmingCharacters(in: .whitespacesAndNewlines)
        guard !cleanEmail.isEmpty else { fail("Please enter your email."); return }
        guard !password.isEmpty else { fail("Please enter your password."); return }

        isWorking = true

        switch mode {
        case .signIn:
            auth.signIn(email: cleanEmail, password: password) { result in
                DispatchQueue.main.async {
                    self.isWorking = false
                    switch result {
                    case .success:
                        self.dismiss()
                    case .failure(let err):
                        let ns = err as NSError
                        print("AUTH signIn error domain:", ns.domain, "code:", ns.code, "info:", ns.userInfo)
                        self.fail(err.localizedDescription)
                    }
                }
            }

        case .signUp:
            auth.createAccount(email: cleanEmail, password: password, role: signupRole) { result in
                DispatchQueue.main.async {
                    self.isWorking = false
                    switch result {
                    case .success:
                        self.dismiss()
                    case .failure(let err):
                        let ns = err as NSError
                        print("AUTH signUp error domain:", ns.domain, "code:", ns.code, "info:", ns.userInfo)
                        self.fail(err.localizedDescription)
                    }
                }
            }
        }
    }

    private func fail(_ msg: String) {
        print("AUTH ERROR:", msg)
        errorMessage = msg
        showError = true
    }
}

