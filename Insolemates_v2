// MARK: - Root View
struct RootView: View {
    @StateObject private var ble = WalkPressureBLE()
    @StateObject private var session = SessionStore()
    @State private var path: [Screen] = []

    var body: some View {
        NavigationStack(path: $path) {
            content
                .navigationDestination(for: Screen.self) { screen in
                    switch screen {
                    case .patientDetail(let patient, let physician, let canSaveSession):
                        PatientDetailView(
                            patient: patient,
                            physician: physician,
                            canSaveSession: canSaveSession
                            )
                        .environmentObject(ble)
                    }
                }
        }
    }

    @ViewBuilder
    private var content: some View {
        if session.loading {
            ProgressView("Loading…")
        } else {
            switch session.route {
            case .signedOut:
                WelcomeView()

            case .caregiver(let email):
                ParentDashboardView(
                    username: email,
                    onLogout: {
                        session.signOut()
                        path.removeAll()
                    }
                )
                .environmentObject(ble)

            case .physician(let email):
                PhysicianDashboardView(
                    username: email,
                    onSelectPatient: { patient in
                        path.append(.patientDetail(patient, email, false))
                    },
                    onLogout: {
                        session.signOut()
                        path.removeAll()
                    }
                )
                .environmentObject(ble)
            }
        }
    }
}

