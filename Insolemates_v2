// MARK: - BLE Manager

struct DiscoveredBLEDevice: Identifiable, Hashable {
    let id: UUID
    let peripheral: CBPeripheral
    var name: String
    var rssi: Int
}

final class WalkPressureBLE: NSObject, ObservableObject, CBCentralManagerDelegate, CBPeripheralDelegate {

    @Published var isConnected: Bool = false
    @Published var statusText: String = "Bluetooth starting…"
    @Published var discoveredDevices: [DiscoveredBLEDevice] = []
    @Published var selectedDeviceID: UUID?

    @Published var stepsTotal: UInt32 = 0
    @Published var stepsToes: UInt32 = 0
    @Published var stepsMid: UInt32 = 0
    @Published var stepsHeel: UInt32 = 0

    private var central: CBCentralManager!
    private var peripheral: CBPeripheral?

    private let serviceUUID = CBUUID(string: "d3b7f3c0-2a1b-4b3d-9af9-2b08a6e3a001")
    private let logCharUUID = CBUUID(string: "d3b7f3c0-2a1b-4b3d-9af9-2b08a6e3a002")

    private var receivingStarted = false
    private var completed = false

    override init() {
        super.init()
        central = CBCentralManager(delegate: self, queue: nil)
    }

    func centralManagerDidUpdateState(_ central: CBCentralManager) {
        switch central.state {
        case .poweredOn:
            DispatchQueue.main.async {
                self.statusText = "Bluetooth ready. Tap Scan."
            }

        case .poweredOff:
            DispatchQueue.main.async {
                self.isConnected = false
                self.statusText = "Bluetooth is off"
                self.discoveredDevices = []
            }

        case .unauthorized:
            DispatchQueue.main.async {
                self.isConnected = false
                self.statusText = "Bluetooth permission not granted"
                self.discoveredDevices = []
            }

        default:
            DispatchQueue.main.async {
                self.isConnected = false
                self.statusText = "Bluetooth unavailable"
                self.discoveredDevices = []
            }
        }
    }

    func startScan() {
        guard central.state == .poweredOn else { return }

        completed = false
        receivingStarted = false

        DispatchQueue.main.async {
            self.discoveredDevices = []
            self.statusText = "Scanning for BLE_StepLogger devices…"
        }

        central.scanForPeripherals(withServices: [serviceUUID], options: [
            CBCentralManagerScanOptionAllowDuplicatesKey: false
        ])
    }

    func stopScan() {
        central.stopScan()
        DispatchQueue.main.async {
            if !self.isConnected {
                self.statusText = "Scan stopped"
            }
        }
    }

    func connectToDevice(_ device: DiscoveredBLEDevice) {
        central.stopScan()

        self.peripheral = device.peripheral
        self.peripheral?.delegate = self

        DispatchQueue.main.async {
            self.statusText = "Connecting to \(device.name)…"
            self.selectedDeviceID = device.id
        }

        central.connect(device.peripheral, options: nil)
    }

    func disconnectCurrentDevice() {
        if let peripheral {
            central.cancelPeripheralConnection(peripheral)
        }
    }

    func centralManager(_ central: CBCentralManager,
                        didDiscover peripheral: CBPeripheral,
                        advertisementData: [String: Any],
                        rssi RSSI: NSNumber) {

        let advertisedName =
            (advertisementData[CBAdvertisementDataLocalNameKey] as? String)
            ?? peripheral.name
            ?? "Unnamed Device"

        let device = DiscoveredBLEDevice(
            id: peripheral.identifier,
            peripheral: peripheral,
            name: advertisedName,
            rssi: RSSI.intValue
        )

        DispatchQueue.main.async {
            if let index = self.discoveredDevices.firstIndex(where: { $0.id == device.id }) {
                self.discoveredDevices[index] = device
            } else {
                self.discoveredDevices.append(device)
            }

            self.discoveredDevices.sort { lhs, rhs in
                lhs.rssi > rhs.rssi
            }

            self.statusText = "Found \(self.discoveredDevices.count) device(s). Select one."
        }
    }

    func centralManager(_ central: CBCentralManager,
                        didConnect peripheral: CBPeripheral) {
        DispatchQueue.main.async {
            self.isConnected = true
            let name = peripheral.name ?? "device"
            self.statusText = "Connected to \(name). Waiting for upload button."
        }
        peripheral.discoverServices([serviceUUID])
    }

    func centralManager(_ central: CBCentralManager,
                        didFailToConnect peripheral: CBPeripheral,
                        error: Error?) {
        DispatchQueue.main.async {
            self.isConnected = false
            self.statusText = "Failed to connect"
        }
    }

    func centralManager(_ central: CBCentralManager,
                        didDisconnectPeripheral peripheral: CBPeripheral,
                        error: Error?) {
        DispatchQueue.main.async {
            self.isConnected = false
            self.statusText = "Disconnected"
            self.selectedDeviceID = nil
        }
    }

    func peripheral(_ peripheral: CBPeripheral, didDiscoverServices error: Error?) {
        guard error == nil else {
            DispatchQueue.main.async { self.statusText = "Service discovery error" }
            return
        }

        guard let services = peripheral.services else { return }

        for service in services where service.uuid == serviceUUID {
            peripheral.discoverCharacteristics([logCharUUID], for: service)
        }
    }

    func peripheral(_ peripheral: CBPeripheral,
                    didDiscoverCharacteristicsFor service: CBService,
                    error: Error?) {
        guard error == nil else {
            DispatchQueue.main.async { self.statusText = "Characteristic discovery error" }
            return
        }

        guard let chars = service.characteristics else { return }

        for characteristic in chars where characteristic.uuid == logCharUUID {
            peripheral.setNotifyValue(true, for: characteristic)
            peripheral.readValue(for: characteristic)
            resetDerivedStats()

            DispatchQueue.main.async {
                self.statusText = "Ready. Press button on the selected device to upload."
            }
        }
    }

    func peripheral(_ peripheral: CBPeripheral,
                    didUpdateValueFor characteristic: CBCharacteristic,
                    error: Error?) {
        guard error == nil else {
            DispatchQueue.main.async { self.statusText = "Read/notify error." }
            return
        }

        guard characteristic.uuid == logCharUUID else { return }
        guard let data = characteristic.value else { return }

        parseIncomingChunk(data)
    }

    private func resetDerivedStats() {
        DispatchQueue.main.async {
            self.stepsTotal = 0
            self.stepsToes = 0
            self.stepsMid = 0
            self.stepsHeel = 0
        }
        receivingStarted = false
        completed = false
    }

    private struct StepBits {
        let toes: Bool
        let mid: Bool
        let heel: Bool
    }

    private func decodeNibble(_ n: UInt8) -> StepBits {
        StepBits(
            toes: (n & 0b0001) != 0,
            mid:  (n & 0b0010) != 0,
            heel: (n & 0b0100) != 0
        )
    }

    private func consumeNibble(_ nib: UInt8,
                               total: inout UInt32,
                               toes: inout UInt32,
                               mid: inout UInt32,
                               heel: inout UInt32) {
        let bits = decodeNibble(nib)
        total += 1
        if bits.toes { toes += 1 }
        if bits.mid { mid += 1 }
        if bits.heel { heel += 1 }
    }

    private func parseIncomingChunk(_ data: Data) {
        if data.count == 1 {
            let b = data[data.startIndex]
            if b == 0xAA { return }

            if b == 0xEE {
                DispatchQueue.main.async {
                    self.stepsTotal = 0
                    self.stepsToes = 0
                    self.stepsMid = 0
                    self.stepsHeel = 0
                    self.statusText = "No log stored (empty)."
                }
                completed = true
                receivingStarted = true
                return
            }
        }

        if data.count == 2 {
            let a = data[data.startIndex]
            let b = data[data.index(after: data.startIndex)]
            if a == 0xEF && b == 0xEF {
                completed = true
                DispatchQueue.main.async {
                    self.statusText = "Upload complete"
                }
                return
            }
        }

        if let s = String(data: data, encoding: .utf8), s == "BTN" {
            DispatchQueue.main.async {
                self.statusText = "Button pressed. Receiving…"
            }
            receivingStarted = true
            return
        }

        if !receivingStarted {
            receivingStarted = true
            DispatchQueue.main.async {
                self.statusText = "Receiving… (streaming log)"
            }
        }

        var newTotal: UInt32 = 0
        var newToes: UInt32 = 0
        var newMid: UInt32 = 0
        var newHeel: UInt32 = 0

        for byte in data {
            let low = byte & 0x0F
            let high = (byte >> 4) & 0x0F

            consumeNibble(low, total: &newTotal, toes: &newToes, mid: &newMid, heel: &newHeel)

            if high != 0x0F {
                consumeNibble(high, total: &newTotal, toes: &newToes, mid: &newMid, heel: &newHeel)
            }
        }

        DispatchQueue.main.async {
            self.stepsTotal &+= newTotal
            self.stepsToes &+= newToes
            self.stepsMid &+= newMid
            self.stepsHeel &+= newHeel

            if !self.statusText.hasPrefix("Upload complete") {
                self.statusText = "Receiving… (\(self.stepsTotal) steps)"
            }
        }
    }
}

// MARK: - Models
enum Role: String, Codable, Hashable {
    case caregiver
    case physician
}

struct Patient: Identifiable, Hashable {
    let id: String
    var name: String
}

struct StepSession: Identifiable, Hashable {
    let id: String
    let totalSteps: Int
    let totalPercent: Int
    let toesPercent: Int
    let midPercent: Int
    let heelPercent: Int
    let createdAt: Date
}

enum Screen: Hashable {
    case patientDetail(Patient, String, Bool)
}

// MARK: - Firestore Services
final class PatientService {
    private let db = Firestore.firestore()

    func fetchPatientsForPhysician(
        physicianUid: String,
        completion: @escaping (Result<[Patient], Error>) -> Void
    ) {
        db.collection("patients")
            .whereField("physicianUid", isEqualTo: physicianUid)
            .getDocuments { snapshot, error in
                if let error {
                    completion(.failure(error))
                    return
                }

                let patients = snapshot?.documents.compactMap { doc -> Patient? in
                    let data = doc.data()
                    guard let name = data["name"] as? String else { return nil }
                    return Patient(id: doc.documentID, name: name)
                } ?? []

                completion(.success(patients))
            }
    }
}

final class PatientAssignmentService {
    private let db = Firestore.firestore()

    func createPatient(
        name: String,
        physicianEmail: String,
        completion: @escaping (Result<Void, Error>) -> Void
    ) {
        guard let caregiverUid = Auth.auth().currentUser?.uid else {
            completion(.failure(NSError(
                domain: "PatientAssignmentService",
                code: -1,
                userInfo: [NSLocalizedDescriptionKey: "No signed-in caregiver"]
            )))
            return
        }

        let cleanEmail = physicianEmail.trimmingCharacters(in: .whitespacesAndNewlines).lowercased()

        db.collection("users")
            .whereField("email", isEqualTo: cleanEmail)
            .whereField("role", isEqualTo: "physician")
            .getDocuments { snapshot, error in
                if let error {
                    completion(.failure(error))
                    return
                }

                guard let doc = snapshot?.documents.first else {
                    completion(.failure(NSError(
                        domain: "PatientAssignmentService",
                        code: -2,
                        userInfo: [NSLocalizedDescriptionKey: "No physician found with that email"]
                    )))
                    return
                }

                let physicianUid = doc.documentID
                
                self.db.collection("users").document(caregiverUid).updateData([
                    "linkedPhysicianUid": physicianUid
                ])

                let patientData: [String: Any] = [
                    "name": name,
                    "caregiverUid": caregiverUid,
                    "physicianUid": physicianUid,
                    "createdAt": FieldValue.serverTimestamp()
                ]

                self.db.collection("patients").addDocument(data: patientData) { error in
                    if let error {
                        completion(.failure(error))
                    } else {
                        completion(.success(()))
                    }
                }
            }
    }
}

