struct PhysicianDashboardView: View {
    let username: String
    var onSelectPatient: (Patient) -> Void
    var onLogout: () -> Void

    @EnvironmentObject var ble: WalkPressureBLE
    @State private var patients: [Patient] = []
    @State private var errorMessage: String?

    private let patientService = PatientService()

    var body: some View {
        VStack(spacing: 16) {
            Text("Physician Home")
                .font(.largeTitle)
                .bold()

            Text("Signed in as \(username)")
                .foregroundStyle(.secondary)

            BLEDevicePickerView(ble: ble)

            
            if let errorMessage {
                Text(errorMessage)
                    .font(.footnote)
                    .foregroundStyle(.red)
            }

            List {
                Section("Patient list") {
                    if patients.isEmpty {
                        Text("No assigned patients yet.")
                            .foregroundStyle(.secondary)
                    } else {
                        ForEach(patients) { patient in
                            Button {
                                onSelectPatient(patient)
                            } label: {
                                HStack {
                                    Image(systemName: "person.crop.circle")
                                    Text(patient.name)
                                }
                            }
                        }
                    }
                }
            }

            Button(role: .destructive) {
                onLogout()
            } label: {
                Text("Log out")
                    .frame(maxWidth: .infinity)
            }
            .buttonStyle(.bordered)
            .padding(.horizontal)
        }
        .padding()
        .onAppear {
            loadPatients()
        }
    }

    private func loadPatients() {
        guard let uid = Auth.auth().currentUser?.uid else {
            errorMessage = "No signed-in physician."
            return
        }

        patientService.fetchPatientsForPhysician(physicianUid: uid) { result in
            DispatchQueue.main.async {
                switch result {
                case .success(let loadedPatients):
                    self.patients = loadedPatients
                    self.errorMessage = nil
                case .failure(let error):
                    self.errorMessage = "Failed to load patients: \(error.localizedDescription)"
                }
            }
        }
    }
}

struct PatientDetailView: View {
    let patient: Patient
    let physician: String
    let canSaveSession: Bool

    @EnvironmentObject var ble: WalkPressureBLE

    private let sessionService = StepSessionService()

    @State private var sessions: [StepSession] = []
    @State private var saveMessage: String?
    @State private var errorMessage: String?

    var body: some View {
        VStack(spacing: 16) {
            Text(patient.name)
                .font(.largeTitle)
                .bold()

            Text("Assigned physician \(physician)")
                .foregroundStyle(.secondary)

            StepSummaryCard(
                total: ble.stepsTotal,
                toes: ble.stepsToes,
                mid: ble.stepsMid,
                heel: ble.stepsHeel
            )

                Button("Save This Session") {
                    saveCurrentSession()
                }
                .buttonStyle(.borderedProminent)
            

            if let saveMessage {
                Text(saveMessage)
                    .font(.footnote)
                    .foregroundStyle(.secondary)
            }

            if let errorMessage {
                Text(errorMessage)
                    .font(.footnote)
                    .foregroundStyle(.red)
            }

            List(sessions) { session in
                VStack(alignment: .leading, spacing: 4) {
                    Text(session.createdAt.formatted())
                        .font(.headline)
                    Text("Total steps: \(session.totalSteps)");  Text("Toes: \(session.toesPercent)%  Mid: \(session.midPercent)%  Heel: \(session.heelPercent)%")
                        .font(.subheadline)
                        .foregroundStyle(.secondary)
                        .font(.subheadline)
                        .foregroundStyle(.secondary)
                }
            }
        }
        .padding()
        .onAppear {
            loadSessions()
        }
    }

    private func saveCurrentSession() {
        sessionService.saveSession(
            patientId: patient.id,
            total: ble.stepsTotal,
            toes: ble.stepsToes,
            mid: ble.stepsMid,
            heel: ble.stepsHeel
        ) { result in
            DispatchQueue.main.async {
                switch result {
                case .success:
                    self.saveMessage = "Session saved"
                    self.errorMessage = nil
                    loadSessions()
                case .failure(let error):
                    self.errorMessage = "Save failed: \(error.localizedDescription)"
                }
            }
        }
    }

    private func loadSessions() {
        sessionService.fetchLastSixMonths(patientId: patient.id) { result in
            DispatchQueue.main.async {
                switch result {
                case .success(let loaded):
                    self.sessions = loaded
                    self.errorMessage = nil
                case .failure(let error):
                    self.errorMessage = "Failed to load sessions: \(error.localizedDescription)"
                }
            }
        }
    }
}
