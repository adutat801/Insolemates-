final class StepSessionService {
    private let db = Firestore.firestore()

    func saveSession(
        patientId: String,
        total: UInt32,
        toes: UInt32,
        mid: UInt32,
        heel: UInt32,
        completion: @escaping (Result<Void, Error>) -> Void
    ) {
        let totalInt = Int(total)

        let toesPercent = totalInt > 0 ? Int((Double(toes) / Double(total)) * 100.0) : 0
        let midPercent = totalInt > 0 ? Int((Double(mid) / Double(total)) * 100.0) : 0
        let heelPercent = totalInt > 0 ? Int((Double(heel) / Double(total)) * 100.0) : 0

        let data: [String: Any] = [
            "totalSteps": totalInt,
            "totalPercent": 100,
            "toesPercent": toesPercent,
            "midPercent": midPercent,
            "heelPercent": heelPercent,
            "createdAt": FieldValue.serverTimestamp()
        ]

        db.collection("patients")
            .document(patientId)
            .collection("sessions")
            .addDocument(data: data) { error in
                if let error {
                    completion(.failure(error))
                } else {
                    completion(.success(()))
                }
            }
    }

    func fetchLastSixMonths(
        patientId: String,
        completion: @escaping (Result<[StepSession], Error>) -> Void
    ) {
        let cutoff = Calendar.current.date(byAdding: .month, value: -6, to: Date()) ?? Date()

        db.collection("patients")
            .document(patientId)
            .collection("sessions")
            .whereField("createdAt", isGreaterThanOrEqualTo: Timestamp(date: cutoff))
            .order(by: "createdAt", descending: true)
            .getDocuments { snapshot, error in
                if let error {
                    completion(.failure(error))
                    return
                }

                let sessions = snapshot?.documents.compactMap { doc -> StepSession? in
                    let data = doc.data()
                    guard
                        let totalSteps = data["totalSteps"] as? Int,
                        let totalPercent = data["totalPercent"] as? Int,
                        let toesPercent = data["toesPercent"] as? Int,
                        let midPercent = data["midPercent"] as? Int,
                        let heelPercent = data["heelPercent"] as? Int,
                        let ts = data["createdAt"] as? Timestamp
                    else {
                        return nil
                    }

                    return StepSession(
                        id: doc.documentID,
                        totalSteps: totalSteps,
                        totalPercent: totalPercent,
                        toesPercent: toesPercent,
                        midPercent: midPercent,
                        heelPercent: heelPercent,
                        createdAt: ts.dateValue()
                    )
                } ?? []

                completion(.success(sessions))
            }
    }
}

// MARK: - Auth Routing
enum AppRoute: Equatable {
    case signedOut
    case caregiver(email: String)
    case physician(email: String)
}

final class SessionStore: ObservableObject {
    @Published var route: AppRoute = .signedOut
    @Published var loading: Bool = true

    private let db = Firestore.firestore()
    private var authHandle: AuthStateDidChangeListenerHandle?

    init() {
        authHandle = Auth.auth().addStateDidChangeListener { [weak self] _, user in
            guard let self else { return }

            if let user {
                self.fetchRoleAndRoute(uid: user.uid, email: user.email ?? "", attempt: 0)
            } else {
                DispatchQueue.main.async {
                    self.loading = false
                    self.route = .signedOut
                }
            }
        }
    }

    private func fetchRoleAndRoute(uid: String, email: String, attempt: Int) {
        DispatchQueue.main.async {
            self.loading = true
        }

        db.collection("users").document(uid).getDocument { [weak self] snap, err in
            guard let self else { return }

            if let err {
                print("Firestore read error:", err.localizedDescription)
                DispatchQueue.main.async {
                    self.loading = false
                    self.route = .signedOut
                }
                return
            }

            guard
                let data = snap?.data(),
                let roleStr = data["role"] as? String
            else {
                if attempt < 6 {
                    DispatchQueue.main.asyncAfter(deadline: .now() + 0.35) {
                        self.fetchRoleAndRoute(uid: uid, email: email, attempt: attempt + 1)
                    }
                    return
                }

                try? Auth.auth().signOut()
                DispatchQueue.main.async {
                    self.loading = false
                    self.route = .signedOut
                }
                return
            }

            DispatchQueue.main.async {
                self.loading = false
                if roleStr == Role.physician.rawValue {
                    self.route = .physician(email: email)
                } else {
                    self.route = .caregiver(email: email)
                }
            }
        }
    }

    func signOut() {
        try? Auth.auth().signOut()
        route = .signedOut
    }
}

final class AuthService {
    private let db = Firestore.firestore()

    func signIn(email: String, password: String, completion: @escaping (Result<Void, Error>) -> Void) {
        Auth.auth().signIn(withEmail: email, password: password) { _, error in
            if let error {
                completion(.failure(error))
                return
            }
            completion(.success(()))
        }
    }

    func createAccount(
        email: String,
        password: String,
        role: Role,
        accessCode: String? = nil,
        completion: @escaping (Result<Void, Error>) -> Void
    ) {
        Auth.auth().createUser(withEmail: email, password: password) { [weak self] result, error in
            guard let self else { return }

            if let error {
                completion(.failure(error))
                return
            }

            guard let user = result?.user else {
                completion(.failure(
                    NSError(
                        domain: "AuthService",
                        code: -1,
                        userInfo: [NSLocalizedDescriptionKey: "Missing created user."]
                    )
                ))
                return
            }

            let uid = user.uid

            if role == .physician {
                let trimmedCode = (accessCode ?? "")
                    .trimmingCharacters(in: .whitespacesAndNewlines)
                    .uppercased()

                guard !trimmedCode.isEmpty else {
                    user.delete(completion: nil)
                    completion(.failure(
                        NSError(
                            domain: "AuthService",
                            code: -2,
                            userInfo: [NSLocalizedDescriptionKey: "Physician access code is required."]
                        )
                    ))
                    return
                }

                self.claimInviteAndCreatePhysician(uid: uid, email: email, accessCode: trimmedCode) { result in
                    switch result {
                    case .success:
                        completion(.success(()))
                    case .failure(let error):
                        user.delete(completion: nil)
                        completion(.failure(error))
                    }
                }

            } else {
                self.createUserDoc(uid: uid, email: email, role: .caregiver) { result in
                    switch result {
                    case .success:
                        completion(.success(()))
                    case .failure(let error):
                        user.delete(completion: nil)
                        completion(.failure(error))
                    }
                }
            }
        }
    }

    private func createUserDoc(
        uid: String,
        email: String,
        role: Role,
        completion: @escaping (Result<Void, Error>) -> Void
    ) {
        let doc: [String: Any] = [
            "email": email,
            "role": role.rawValue,
            "createdAt": FieldValue.serverTimestamp()
        ]

        db.collection("users").document(uid).setData(doc) { error in
            if let error {
                completion(.failure(error))
                return
            }
            completion(.success(()))
        }
    }

    private func claimInviteAndCreatePhysician(
        uid: String,
        email: String,
        accessCode: String,
        completion: @escaping (Result<Void, Error>) -> Void
    ) {
        let inviteRef = db.collection("invites").document(accessCode)
        let userRef = db.collection("users").document(uid)

        db.runTransaction({ transaction, errorPointer in
            let inviteSnap: DocumentSnapshot

            do {
                inviteSnap = try transaction.getDocument(inviteRef)
            } catch let error as NSError {
                errorPointer?.pointee = error
                return nil
            }

            guard let data = inviteSnap.data() else {
                errorPointer?.pointee = NSError(
                    domain: "AuthService",
                    code: -3,
                    userInfo: [NSLocalizedDescriptionKey: "Invalid physician access code."]
                )
                return nil
            }

            let used = (data["used"] as? Bool) ?? false
            let role = (data["role"] as? String) ?? ""

            guard role == Role.physician.rawValue else {
                errorPointer?.pointee = NSError(
                    domain: "AuthService",
                    code: -4,
                    userInfo: [NSLocalizedDescriptionKey: "This code is not for physician signup."]
                )
                return nil
            }

            guard used == false else {
                errorPointer?.pointee = NSError(
                    domain: "AuthService",
                    code: -5,
                    userInfo: [NSLocalizedDescriptionKey: "This physician access code has already been used."]
                )
                return nil
            }

            transaction.updateData([
                "used": true,
                "usedBy": uid,
                "usedAt": FieldValue.serverTimestamp()
            ], forDocument: inviteRef)

            transaction.setData([
                "email": email,
                "role": Role.physician.rawValue,
                "createdAt": FieldValue.serverTimestamp()
            ], forDocument: userRef)

            return nil
        }) { _, error in
            if let error {
                completion(.failure(error))
                return
            }
            completion(.success(()))
        }
    }
}

// MARK: - Shared Summary Card
struct StepBarDatum: Identifiable {
    let id = UUID()
    let label: String
    let value: Int
}

struct StepSummaryCard: View {
    let total: UInt32
    let toes: UInt32
    let mid: UInt32
    let heel: UInt32

    private func pct(_ x: UInt32) -> Int {
        guard total > 0 else { return 0 }
        return Int((Double(x) / Double(total)) * 100.0)
    }

    private var chartData: [StepBarDatum] {
        [
            .init(label: "Total", value: Int(total)),
            .init(label: "Toes", value: Int(toes)),
            .init(label: "Mid", value: Int(mid)),
            .init(label: "Heel", value: Int(heel))
        ]
    }

    var body: some View {
        VStack(alignment: .leading, spacing: 12) {
            HStack {
                Text("Total steps").font(.headline)
                Spacer()
                Text("\(Int(total))").font(.headline)
            }

            Chart(chartData) { item in
                BarMark(
                    x: .value("Category", item.label),
                    y: .value("Steps", item.value)
                )
            }
            .frame(height: 180)

            VStack(alignment: .leading, spacing: 6) {
                HStack { Text("Toes active"); Spacer(); Text("\(pct(toes))%") }
                HStack { Text("Midfoot active"); Spacer(); Text("\(pct(mid))%") }
                HStack { Text("Heel active"); Spacer(); Text("\(pct(heel))%") }
            }
            .font(.subheadline)
            .foregroundStyle(.secondary)
        }
        .padding()
        .background(Color(.secondarySystemBackground))
        .clipShape(RoundedRectangle(cornerRadius: 14))
    }
}

// MARK: - BLEDevicePickerview
struct BLEDevicePickerView: View {
    @ObservedObject var ble: WalkPressureBLE

    var body: some View {
        VStack(spacing: 14) {

            // Title
            HStack {
                Image(systemName: "dot.radiowaves.left.and.right")
                Text("Device Connection")
                    .font(.headline)
                Spacer()
            }

            // Connection status badge
            HStack {
                Circle()
                    .fill(ble.isConnected ? Color.green : Color.orange)
                    .frame(width: 10, height: 10)

                Text(ble.isConnected ? "Connected" : "Not Connected")
                    .font(.subheadline)

                Spacer()
            }

            // Scan + Disconnect buttons
            HStack(spacing: 12) {
                Button(action: {
                    ble.startScan()
                }) {
                    Label("Scan", systemImage: "magnifyingglass")
                        .frame(maxWidth: .infinity)
                }
                .buttonStyle(.borderedProminent)

                if ble.isConnected {
                    Button(action: {
                        ble.disconnectCurrentDevice()
                    }) {
                        Label("Disconnect", systemImage: "xmark.circle")
                            .frame(maxWidth: .infinity)
                    }
                    .buttonStyle(.bordered)
                }
            }

            // Device list
            if ble.discoveredDevices.isEmpty {
                Text("Tap “Scan” to find nearby devices")
                    .font(.footnote)
                    .foregroundColor(.secondary)
                    .padding(.top, 4)
            } else {
                VStack(spacing: 8) {
                    ForEach(ble.discoveredDevices) { device in
                        Button(action: {
                            ble.connectToDevice(device)
                        }) {
                            HStack {
                                VStack(alignment: .leading) {
                                    Text(device.name)
                                        .fontWeight(.medium)

                                    Text("Signal: \(device.rssi)")
                                        .font(.caption)
                                        .foregroundColor(.secondary)
